"{\n  \"diabetes_mellitus\": {\n    \"Microvascular_Complications\": {\n      \"description\": \"This category encompasses clinical outcomes related to damage to small blood vessels, including diabetic retinopathy, nephropathy, and neuropathy.\"\n    },\n    \"Macrovascular_Disease\": {\n      \"description\": \"This category focuses on clinical outcomes related to large blood vessel disease, such as coronary artery disease, peripheral artery disease, and stroke.\"\n    },\n    \"Glycemic_Control\": {\n      \"description\": \"This category includes clinical outcomes directly measuring blood sugar regulation, primarily focusing on HbA1c levels and fasting plasma glucose.\"\n    },\n    \"Diabetic_Foot_Ulcers\": {\n      \"description\": \"This category specifically addresses clinical outcomes related to the development and progression of diabetic foot ulcers, including wound healing and amputation risk.\"\n    },\n    \"Healthcare_Utilization\": {\n      \"description\": \"This category represents clinical outcomes related to the frequency and type of healthcare services used by individuals with diabetes, such as hospitalizations, emergency room visits, and specialist consultations.\"\n    }\n  }\n}"