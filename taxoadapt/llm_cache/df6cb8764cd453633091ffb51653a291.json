"{\n  \"diabetes_mellitus\": {\n    \"Diagnosis\": {\n      \"description\": \"This clinical task focuses on identifying the presence of diabetes mellitus, often involving blood glucose testing and assessment of related symptoms.\"\n    },\n    \"Risk_Prediction\": {\n      \"description\": \"This task involves assessing an individual's likelihood of developing diabetes mellitus based on factors like family history, lifestyle, and biomarkers.\"\n    },\n    \"Treatment_Planning\": {\n      \"description\": \"This clinical task centers on developing individualized strategies for managing diabetes, including medication, diet, and exercise recommendations.\"\n    },\n    \"Complication_Detection\": {\n      \"description\": \"This task aims to identify and diagnose diabetes-related complications such as neuropathy, retinopathy, or nephropathy, often through specialized screenings and examinations.\"\n    },\n    \"Patient_Monitoring\": {\n      \"description\": \"This clinical task involves tracking a patient's blood glucose levels, HbA1c, and overall health status to ensure effective diabetes management and adjust treatment as needed.\"\n    }\n  }\n}"